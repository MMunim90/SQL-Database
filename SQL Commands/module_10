				FROM Employees
				WHERE Salary > (SELECT MIN(Salary)
								FROM Employees
                                WHERE Salary > (SELECT MIN(Salary)
												FROM Employees))); 
                                                


SELECT *
FROM Employees
WHERE Salary = (SELECT DISTINCT Salary
				FROM Employees
				ORDER BY Salary ASC
                LIMIT 1
                OFFSET 2);
                



