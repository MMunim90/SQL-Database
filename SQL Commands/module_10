-- 1

SELECT *
FROM Employees
WHERE Salary = (SELECT MAX(Salary)
				FROM Employees
                WHERE Salary < (SELECT MAX(Salary)
								FROM Employees
                                WHERE Salary < (SELECT MAX(Salary)
												FROM Employees)));
                
                
                
SELECT *
FROM Employees
WHERE Salary = (SELECT DISTINCT Salary
				FROM Employees
                ORDER BY SALARY DESC
				LIMIT 1
				OFFSET 2);
                
                
